{% macro bool_options(value, uni_text_enabled, uni_text_disabled) %}
  <option value="1"{{ value ? ' selected="selected"' : '' }}>{{ uni_text_enabled }}</option>
  <option value="0"{{ not value ? ' selected="selected"' : '' }}>{{ uni_text_disabled }}</option>
{% endmacro %}

{% import _self as form %}

{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-module" data-bs-toggle="tooltip" title="{{ uni_button_save }}"
          class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ uni_button_cancel }}" class="btn btn-light"><i
            class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible">
      <i class="fa-solid fa-circle-exclamation"></i> {{ error_warning }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}

    <div class="card">
      <div class="card-header"><i class="fa-solid fa-pencil"></i> {{ uni_text_edit }}</div>
      <div class="card-body">
        <form id="form-module" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <div class="row mb-3">
            <label for="input-status" class="col-sm-4 col-form-label">{{ uni_entry_status }}</label>
            <div class="col-sm-8">
              <select name="module_mt_uni_credit_status" id="input-status" class="form-select">
                {{ form.bool_options(module_mt_uni_credit_status, uni_text_enabled, uni_text_disabled) }}
              </select>
              <div class="form-text">{{ uni_entry_status_small }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-unicid" class="col-sm-4 col-form-label">{{ uni_entry_unicid }}</label>
            <div class="col-sm-8">
              <input type="text" name="module_mt_uni_credit_unicid" value="{{ module_mt_uni_credit_unicid|default('') }}"
                placeholder="{{ uni_entry_unicid }}" id="input-unicid" class="form-control" />
              <div class="form-text">{{ uni_entry_unicid_small }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-reklama" class="col-sm-4 col-form-label">{{ uni_entry_reklama }}</label>
            <div class="col-sm-8">
              <select name="module_mt_uni_credit_reklama" id="input-reklama" class="form-select">
                {{ form.bool_options(module_mt_uni_credit_reklama, uni_text_enabled, uni_text_disabled) }}
              </select>
              <div class="form-text">{{ uni_entry_reklama_small }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-cart" class="col-sm-4 col-form-label">{{ uni_entry_cart }}</label>
            <div class="col-sm-8">
              <select name="module_mt_uni_credit_cart" id="input-cart" class="form-select">
                {{ form.bool_options(module_mt_uni_credit_cart, uni_text_enabled, uni_text_disabled) }}
              </select>
              <div class="form-text">{{ uni_entry_cart_small }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-debug" class="col-sm-4 col-form-label">{{ uni_entry_debug }}</label>
            <div class="col-sm-8">
              <select name="module_mt_uni_credit_debug" id="input-debug" class="form-select">
                {{ form.bool_options(module_mt_uni_credit_debug, uni_text_enabled, uni_text_disabled) }}
              </select>
              <div class="form-text">{{ uni_entry_debug_small }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-gap" class="col-sm-4 col-form-label">{{ uni_entry_gap }}</label>
            <div class="col-sm-8">
              <input type="number" min="0" step="1" name="module_mt_uni_credit_gap"
                value="{{ module_mt_uni_credit_gap|default(0) }}" placeholder="{{ uni_entry_gap }}" id="input-gap"
                class="form-control" />
              <div class="form-text">{{ uni_entry_gap_small }}</div>
            </div>
          </div>

          <div class="row mb-3">
            <label for="input-cache-api-token" class="col-sm-4 col-form-label">{{ uni_entry_cache_api_token }}</label>
            <div class="col-sm-8">
              <input type="text" name="module_mt_uni_credit_cache_api_token" autocomplete="off"
                value="{{ module_mt_uni_credit_cache_api_token|default('') }}"
                placeholder="{{ uni_entry_cache_api_token }}" id="input-cache-api-token" class="form-control font-monospace" />
              <div class="form-text">{{ uni_entry_cache_api_token_small }}</div>
              <div class="form-text"><code class="small user-select-all">{{ uni_cache_api_example_url }}</code></div>
              <div class="form-text text-muted small">{{ uni_cache_api_url_hint }}</div>
            </div>
          </div>
        </form>

        <hr class="my-4" />
        <h2 class="h5 mb-3">{{ uni_kop_section_title }}</h2>
        <p class="text-muted small mb-3">{{ uni_kop_section_hint }}</p>
        <form id="form-kop-map" action="{{ save_kop }}" method="post" data-oc-toggle="ajax">
          <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
              <thead>
                <tr>
                  <th class="text-nowrap" style="width: 1%">{{ uni_kop_col_id }}</th>
                  <th>{{ uni_kop_col_name }}</th>
                  <th style="min-width: 12rem">{{ uni_kop_col_kop }}</th>
                  <th style="min-width: 12rem">{{ uni_kop_col_promo }}</th>
                </tr>
              </thead>
              <tbody>
                {% for row in kop_mappings %}
                <tr>
                  <td class="text-nowrap">{{ row.category_id }}</td>
                  <td>{{ row.name }}</td>
                  <td>
                    <input type="text" name="kop_map[{{ row.category_id }}][kop]" value="{{ row.kop }}"
                      maxlength="64" class="form-control form-control-sm" autocomplete="off" />
                  </td>
                  <td>
                    <input type="text" name="kop_map[{{ row.category_id }}][promo]" value="{{ row.promo }}"
                      maxlength="64" class="form-control form-control-sm" autocomplete="off" />
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="4" class="text-center text-muted">{{ uni_kop_empty }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </form>
        <div class="d-flex flex-wrap gap-2 justify-content-end align-items-center mt-3">
          <form id="form-kop-refresh" action="{{ refresh_kop }}" method="post" data-oc-toggle="ajax" class="m-0">
            <button type="submit" class="btn btn-outline-secondary" data-bs-toggle="tooltip"
              title="{{ uni_button_refresh_kop }}">
              <i class="fa-solid fa-rotate"></i> {{ uni_button_refresh_kop }}
            </button>
          </form>
          <button type="submit" form="form-kop-map" class="btn btn-primary" data-bs-toggle="tooltip"
            title="{{ uni_button_save_kop }}">
            <i class="fa-solid fa-table-list"></i> {{ uni_button_save_kop }}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
{{ footer }}
